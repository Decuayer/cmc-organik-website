# Bu klasör kullanıcı tarafından yüklenen dosyaları barındırır.
# PHP dosyalarının çalıştırılmasını (RCE önleme) engelle — ikinci savunma katmanı.

<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.ph(p[3457]?|t|tml)$">
    Require all denied
</FilesMatch>
